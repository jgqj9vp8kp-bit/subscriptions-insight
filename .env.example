VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional demo-only fallback when Supabase is not configured. Disabled by default in production.
VITE_ENABLE_LOCAL_AUTH=false

# Server-side only. Set in Vercel/Lovable/server runtime, never expose with VITE_.
FUNNELFOX_SECRET=your_funnelfox_secret

# Frontend switch for real FunnelFox sync through the same-origin server proxy.
VITE_FUNNELFOX_MOCK=false
