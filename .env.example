VITE_SUPABASE_URL=https://wsjbpkderyhdefukppvb.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_9_YvJkk65zgFHZhacO2nHw_8C_ty5xD

# Optional demo-only fallback when Supabase is not configured. Disabled by default in production.
VITE_ENABLE_LOCAL_AUTH=false

# Server-side only. Set as a Supabase Edge Function secret, never expose with VITE_.
FUNNELFOX_SECRET=your_funnelfox_secret

# Server-side only. Set as Supabase Edge Function secrets for capsuled-facebook-sync.
# Never expose these with VITE_ or ship them to the browser.
CAPSULED_API_BASE_URL=https://api.capsuled.example
CAPSULED_API_TOKEN=your_capsuled_api_token

# Frontend switch for real FunnelFox sync through Supabase Edge Functions.
VITE_FUNNELFOX_MOCK=false
VITE_FUNNELFOX_PROXY_URL=https://wsjbpkderyhdefukppvb.supabase.co/functions/v1

# Persistent Supabase transaction warehouse. Set to false to keep analytics browser-only.
VITE_USE_TRANSACTION_WAREHOUSE=true

# Cohorts page read path. "clickhouse" (default): server-side ClickHouse via the
# clickhouse-cohorts Edge Function drives the table, with the client compute kept
# as the on-failure fallback. "legacy": client-side compute only. The two engines
# never run simultaneously.
VITE_COHORTS_DATA_SOURCE=clickhouse

# ClickHouse Analytics Warehouse secrets are server-side only.
# Set these as Supabase Edge Function Secrets, never as VITE_ variables:
# CLICKHOUSE_HOST
# CLICKHOUSE_USERNAME
# CLICKHOUSE_DATABASE
# CLICKHOUSE_PASSWORD

# FB Cohorts user-cost reporting-date configuration (server-side only).
# Use IANA timezone names. Account mapping wins over the default.
# FB_META_DEFAULT_TIMEZONE=America/Los_Angeles
# FB_META_ACCOUNT_TIMEZONES_JSON={"act_123":"America/Los_Angeles","act_456":"UTC"}
# Server-only: expose paginated FB allocation diagnostics inside the existing
# authenticated Cohorts response/UI. Keep disabled outside validation windows.
# FB_COHORT_ALLOCATION_DIAGNOSTICS_ENABLED=false
